# Replicate (required for AI generation)
# Get yours at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Optional: override the default Replicate model
# Default: stability-ai/sdxl (SDXL img2img)
# Example with pinned version: stability-ai/sdxl:39ed52f2a78e934b3ba6e2a89f5b1c712de7dfea535525255b1aa35c5565e08b
REPLICATE_MODEL=

# Optional: background-removal model run before stylization (unset = prompt-only isolation)
# Example: 851-labs/background-removal
REPLICATE_EXTRACT_MODEL=

# Vercel Blob (required for image uploads)
# Create a Blob store in Vercel → Storage, or run: vercel env pull
BLOB_READ_WRITE_TOKEN=

# Supabase (auth + server-side token ledger)
# Create a project at https://supabase.com — run supabase/migrations/001_token_system.sql in SQL Editor
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (one-time token packs — test mode for development)
# Dashboard → Developers → API keys (test mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# One-time price IDs (Products → create 3 one-time prices in test mode)
STRIPE_PRICE_ID_TRY_IT=
STRIPE_PRICE_ID_CREATOR=
STRIPE_PRICE_ID_ELITE=

# Optional: public app URL for Stripe redirect URLs in production
# Example: https://ink-n-motion.vercel.app
NEXT_PUBLIC_APP_URL=
