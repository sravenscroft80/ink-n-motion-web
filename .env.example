# Replicate (required for AI generation)
# Get yours at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Optional: override the default Replicate model
# Default: stability-ai/sdxl (SDXL img2img)
# Example with pinned version: stability-ai/sdxl:39ed52f2a78e934b3ba6e2a89f5b1c712de7dfea535525255b1aa35c5565e08b
REPLICATE_MODEL=

# Optional: background-removal model run before stylization (unset = prompt-only isolation)
# Example: 851-labs/background-removal
REPLICATE_EXTRACT_MODEL=

# Optional: image-to-video model for Motion Studio and scene animation
# REPLICATE_VIDEO_MODEL=bytedance/seedance-1-lite

# Vercel Blob (required for image uploads)
# Create a Blob store in Vercel → Storage, or run: vercel env pull
BLOB_READ_WRITE_TOKEN=

# Supabase (auth + server-side token ledger)
# Dashboard → Project Settings → API Keys
# Run supabase/migrations/*.sql in SQL Editor first.
NEXT_PUBLIC_SUPABASE_URL=
# Client key: prefer Publishable key (sb_publishable_…). Legacy anon JWT (eyJ…) also works.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only: prefer Secret key (sb_secret_…). Legacy service_role JWT (eyJ…) also works.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (one-time token packs — test mode for development)
# Dashboard → Developers → API keys (test mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public site URL for Stripe redirect URLs
# Production: https://ink-n-motion-web.vercel.app
# Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# Legacy alias (optional fallback if NEXT_PUBLIC_SITE_URL is unset)
NEXT_PUBLIC_APP_URL=
